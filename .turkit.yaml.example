# Copy to .turkit.yaml at your repo root to override build tool detection.
# All fields optional. Run /turkit:turkit-init to auto-generate one tailored to your project.

commands:
  # Optional local dev server command, used only by skills that need a live app.
  dev: pnpm dev
  check: pnpm typecheck
  lint: pnpm lint
  fmt: pnpm format
  test: pnpm test
  build: pnpm build
  # Optional stack-specific command used by /turkit-react:react-review.
  react_review: pnpm react-review

# Branch compared against by review / PR skills.
# Defaults to `git symbolic-ref refs/remotes/origin/HEAD` then `main`.
base_branch: main

# Optional workflow policy used by ticket execution skills.
workflow:
  workspace: feature_branch # or worktree_required
  worktree_dir: .worktrees
  branch_template: "{ticket_id_lower}-{slug}"
  token_budget: low # low | normal | high
  init:
    - pnpm install

# Optional operator-facing output style. Use compact to keep agent replies short.
output:
  style: compact # compact | standard | full
  language: auto # auto | fr | en
  technical_terms: keep-english # keep-english | translate-when-natural

# Optional project rule sources loaded by planning/execution/review skills.
rules:
  docs:
    - CLAUDE.md
    - AGENTS.md
    - docs/conventions/*.md

# Optional VCS host commands used by /turkit:ship (PR create) and handoff (PR view).
# If unset, ship auto-detects `gh`, then `glab`, then falls back to printing the PR
# title/body for you to open manually. Supported variables: $TITLE, $BODY_FILE, $PR_NUMBER.
# See docs/contracts/vcs-host-detection.md for the resolution order.
vcs:
  pr_create: gh pr create --title "$TITLE" --body-file "$BODY_FILE"
  pr_view: gh pr view "$PR_NUMBER"

# Optional deployed preview configuration used by preview-test.
preview:
  # URL template for PR previews. {pr_number} is substituted after PR detection.
  url_template: "pr-{pr_number}.beta.example.com"
  # Optional selector or text that indicates the preview is ready.
  wait_for: ""
  # Visual analysis mode for screenshots: auto | claude | gemini | off.
  vision: auto

# Optional review strictness knobs read by the review skills/rubrics. Defaults shown.
review:
  strictness: standard # relaxed | standard | strict
  comments: allow-why-only # allow | allow-why-only | zero-new-comments
  react:
    min_version: 19
